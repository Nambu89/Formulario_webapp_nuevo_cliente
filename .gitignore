# ── Secrets & environment ──────────────────────────────
.env
.env.*
!.env.example

# ── Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/

# ── Node / React ───────────────────────────────────────
node_modules/
Frontend/node_modules/

# ── Build artifacts ────────────────────────────────────
# static/ is generated by the Docker build (npm run build → static/)
# Don't commit it; it is regenerated on every build.
static/
Frontend/build/

# ── Uploaded files (runtime data) ─────────────────────
uploads/
Backend/uploads/

# ── IDE / editor ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ───────────────────────────────────────────────
*.log
npm-debug.log*

# ── Test / coverage ────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
